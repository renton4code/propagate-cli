# Local development defaults for the backend and CLI.
PROPAGATE_API_URL=http://localhost:8080
PROPAGATE_API_PORT=8080
PROPAGATE_DB_PORT=55432
SUPABASE_STUDIO_PORT=54323
SUPABASE_PG_META_CRYPTO_KEY=propagate-local-pg-meta-key
PORT=8080

# Use this when running the backend directly on the host against compose Postgres.
PROPAGATE_DATABASE_URL=postgres://postgres:postgres@localhost:55432/postgres?sslmode=disable
