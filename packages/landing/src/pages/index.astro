---
import Layout from "../layouts/Layout.astro";
import FishSvg from "../components/FishSvg.astro";
import { SlackScene } from "../components/SlackScene";
import { TerminalFlow } from "../components/TerminalFlow";
import type { TerminalDef } from "../components/TerminalFlow";

const terminals: TerminalDef[] = [
  {
    step: "01",
    label: "Admin sets up the project",
    user: "alice@acme",
    dir: "~/my-project",
    lines: [
      { kind: "cmd",    text: 'propagate init --handle alice@example.com --team-name "Acme API"' },
      { kind: "output", text: "  Checking for existing identity..." },
      { kind: "output", text: "  ✓ Keypair generated → ~/.propagate/id_ed25519" },
      { kind: "output", text: "  ✓ Identity set: alice@example.com" },
      { kind: "blank" },
      { kind: "output", text: "  Scanning repository for .env files..." },
      { kind: "output", text: "  Found .env  (2 variables)" },
      { kind: "blank" },
      { kind: "output", text: "    DATABASE_URL   d***l   scope: dev" },
      { kind: "output", text: "    API_TOKEN      s***9   scope: dev" },
      { kind: "blank" },
      { kind: "output", text: "  Encrypting 2 variables for scope: dev..." },
      { kind: "output", text: "  ✓ Uploaded to cloud" },
      { kind: "output", text: "  ✓ propagate.yaml written  (rev_00001)" },
    ],
  },
  {
    step: "02",
    label: "New developer requests access",
    user: "bob@acme",
    dir: "~/my-project",
    lines: [
      { kind: "cmd",    text: "propagate init --handle bob@example.com" },
      { kind: "output", text: "  ✓ Keypair generated → ~/.propagate/id_ed25519" },
      { kind: "output", text: "  ✓ Identity set: bob@example.com" },
      { kind: "output", text: "  ! propagate.yaml found. Run team join to request access." },
      { kind: "blank" },
      { kind: "cmd",    text: "propagate team join --scope dev=read" },
      { kind: "output", text: "  Reading propagate.yaml..." },
      { kind: "output", text: "  ✓ Join request added to propagate.yaml" },
      { kind: "blank" },
      { kind: "output", text: "  You do not have secret access yet." },
      { kind: "output", text: "  Next steps:" },
      { kind: "output", text: "    1. git add propagate.yaml && git commit" },
      { kind: "output", text: "    2. Open a pull request" },
      { kind: "output", text: "    3. Ask an admin to run propagate config push" },
    ],
  },
  {
    step: "03",
    label: "Admin approves after config update (can be a step in CI)",
    user: "alice@acme",
    dir: "~/my-project",
    lines: [
      { kind: "cmd",    text: "git pull" },
      { kind: "output", text: "  1 file changed  (propagate.yaml)" },
      { kind: "blank" },
      { kind: "cmd",    text: "propagate config push" },
      { kind: "output", text: "  Pending joins:" },
      { kind: "output", text: "    bob@example.com   dev=read   sha256:def456..." },
      { kind: "blank" },
      { kind: "output", text: "  ✓ Approved: bob@example.com" },
      { kind: "output", text: "  ✓ Scope key encrypted for bob's public key" },
      { kind: "output", text: "  ✓ 1 envelope uploaded  (rev_00002)" },
      { kind: "output", text: "  ✓ propagate.yaml updated" },
    ],
  },
  {
    step: "04",
    label: "Developer pulls encrypted secrets",
    user: "bob@acme",
    dir: "~/my-project",
    lines: [
      { kind: "cmd",    text: "propagate env pull --scope dev" },
      { kind: "output", text: "  Reading propagate.yaml..." },
      { kind: "output", text: "  Fetching encrypted variables..." },
      { kind: "output", text: "  Decrypting with ~/.propagate/id_ed25519..." },
      { kind: "output", text: "  ✓ DATABASE_URL  →  .env" },
      { kind: "output", text: "  ✓ API_TOKEN     →  .env" },
      { kind: "output", text: "  ✓ 2 variables written to .env" },
      { kind: "blank" },
      { kind: "cmd",    text: "cat .env" },
      { kind: "output", text: "  DATABASE_URL=p***************2" },
      { kind: "output", text: "  API_TOKEN=s***********9" },
    ],
  },
];

const features = [
  {
    icon: "🔐",
    title: "End-to-end encrypted",
    description:
      "Variables are encrypted locally with your public/private key pair before leaving your machine. The server never sees plaintext values.",
  },
  {
    icon: "⌨️",
    title: "CLI-first",
    description:
      "Everything happens in the terminal. No browser required, no dashboard to log in to. Designed to fit into the way developers already work.",
  },
  {
    icon: "👥",
    title: "Team access control",
    description:
      "Invite teammates by public key. Assign roles and environment scopes. Review membership changes in Git like any other code.",
  },
  {
    icon: "📄",
    title: "Git-backed config",
    description:
      "Team configuration lives in propagate.yaml in your repo. Access changes are pull requests — reviewable, diffable, and auditable.",
  },
  {
    icon: "🔑",
    title: "Key-based identity",
    description:
      "No passwords, no OAuth. Your identity is a keypair stored in ~/.propagate. Works great for both humans and AI coding agents.",
  },
  {
    icon: "🌍",
    title: "Multi-environment",
    description:
      "Separate scopes for dev, staging, and prod. Grant teammates access to the environments they need — and nothing more.",
  },
];

---

<Layout>
  <!-- Nav -->
  <header
    class="fixed top-0 inset-x-0 z-50"
    style="background:#0c0c0c;border-bottom:2px solid #fff"
  >
    <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
      <div class="flex items-center gap-1">
        <div class="mt-[3px]"><FishSvg width={30} height={22} /></div>
        <span style="font-weight:800;letter-spacing:-0.02em">propagate</span>
      </div>
      <nav class="hidden md:flex items-center gap-1">
        <a
          href="#features"
          class="px-4 py-1.5 text-sm font-semibold"
          style="color:#888;border:2px solid transparent"
          onmouseover="this.style.color='#fff';this.style.borderColor='#fff';this.style.boxShadow='3px 3px 0 #FFE500'"
          onmouseout="this.style.color='#888';this.style.borderColor='transparent';this.style.boxShadow='none'"
        >Features</a>
        <a
          href="#how-it-works"
          class="px-4 py-1.5 text-sm font-semibold"
          style="color:#888;border:2px solid transparent"
          onmouseover="this.style.color='#fff';this.style.borderColor='#fff';this.style.boxShadow='3px 3px 0 #FFE500'"
          onmouseout="this.style.color='#888';this.style.borderColor='transparent';this.style.boxShadow='none'"
        >How it works</a>
        <a
          href="https://github.com/renton4code/propagate-cli"
          target="_blank"
          rel="noopener noreferrer"
          class="ml-3 flex items-center gap-1.5 px-4 py-1.5 text-sm font-bold"
          style="border:2px solid #fff;color:#000;background:#FFE500;box-shadow:3px 3px 0 #fff"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
          </svg>
          GitHub
        </a>
      </nav>
    </div>
  </header>

  <main class="pt-14">
    <!-- Hero: Slack Scene — no z-index so fish show through -->
    <SlackScene client:load />

    <!-- Terminal Flow -->
    <section style="position:relative;z-index:1;border-top:2px solid #fff;background:#0c0c0c">
      <TerminalFlow terminals={terminals} client:load />
    </section>

    <!-- Features — no bg so fish show through padding; cards are solid -->
    <section id="features" class="py-24 px-6" style="border-top:2px solid #fff">
      <div class="max-w-6xl mx-auto">
        <div class="mb-16">
          <p class="eyebrow mb-3">Features</p>
          <h2 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4" style="letter-spacing:-0.03em">
            <span style="display:block;margin-bottom:0.2em">Designed for how</span><span>teams actually <span style="font-family:'Instrument Serif','Iowan Old Style',Georgia,serif;font-style:italic;font-weight:400;background:rgba(255,229,0,0.2);padding:0 0.15em">work</span></span>
          </h2>
          <p class="text-lg max-w-xl" style="color:#888">
            No new accounts, no browser required. A CLI that fits into the way developers already work.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-0" style="border:2px solid #fff">
          {
            features.map((f, i) => (
              <div
                class="p-6 group cursor-default"
                style={`position:relative;z-index:1;background:#111;border-right:${(i+1) % 3 === 0 ? '0' : '2px solid #fff'};border-bottom:${i < 3 ? '2px solid #fff' : '0'};transition:background 0.15s,box-shadow 0.15s`}
                onmouseover="this.style.background='#1e1e1e';this.style.boxShadow='inset -4px -4px 0 #FFE500'"
                onmouseout="this.style.background='#111';this.style.boxShadow='none'"
              >
                <div class="text-3xl mb-4">{f.icon}</div>
                <h3 class="font-bold text-base mb-2" style="color:#fff">{f.title}</h3>
                <p class="text-sm leading-relaxed" style="color:#888">{f.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- How it works -->
    <!-- How it works — no bg so fish show through padding; grid card is solid -->
    <section id="how-it-works" class="py-24 px-6" style="border-top:2px solid #fff">
      <div class="max-w-6xl mx-auto">

        <div class="grid lg:grid-cols-2 gap-0" style="position:relative;z-index:1;border:2px solid #fff;box-shadow:6px 6px 0 #FFE500;background:#111">

          <!-- Left: text -->
          <div class="p-10 flex flex-col justify-center" style="border-right:2px solid #fff;background:#111">
            <p class="eyebrow mb-4">How it works</p>
            <h2 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-6" style="letter-spacing:-0.03em">
              <span style="display:block;margin-bottom:0.2em">Simple,</span><span style="display:block;margin-bottom:0.2em">declarative,</span><span style="font-family:'Instrument Serif','Iowan Old Style',Georgia,serif;font-style:italic;font-weight:400;background:rgba(255,229,0,0.2);padding:0 0.15em">e2e encrypted.</span>
            </h2>
            <p class="text-base leading-relaxed mb-8" style="color:#bbb">
              Your entire team config lives in <code style="font-family:'JetBrains Mono',monospace;color:#FFE500;font-size:0.9em">propagate.yaml</code> — committed to Git, reviewed in PRs, auditable forever. Access changes are code changes.
            </p>
            <ul class="space-y-3 text-sm" style="color:#888">
              <li class="flex items-start gap-3">
                <span style="color:#FFE500;font-weight:800;flex-shrink:0">→</span>
                <span>Members and their scopes declared in one place</span>
              </li>
              <li class="flex items-start gap-3">
                <span style="color:#FFE500;font-weight:800;flex-shrink:0">→</span>
                <span>Join requests arrive as YAML diffs — approve with <code style="font-family:'JetBrains Mono',monospace;color:#FFE500;font-size:0.9em">propagate config push</code></span>
              </li>
              <li class="flex items-start gap-3">
                <span style="color:#FFE500;font-weight:800;flex-shrink:0">→</span>
                <span>Every variable is encrypted per-scope before upload — server sees only ciphertext</span>
              </li>
            </ul>
          </div>

          <!-- Right: propagate.yaml file -->
          <div style="background:#0c0c0c">
            <!-- file tab -->
            <div style="border-bottom:2px solid #fff;padding:0.6rem 1.25rem;display:flex;align-items:center;gap:0.75rem">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <rect x="1" y="1" width="12" height="12" rx="1" stroke="#FFE500" stroke-width="1.5"/>
                <line x1="4" y1="4.5" x2="10" y2="4.5" stroke="#FFE500" stroke-width="1.2"/>
                <line x1="4" y1="7" x2="10" y2="7" stroke="#FFE500" stroke-width="1.2"/>
                <line x1="4" y1="9.5" x2="7" y2="9.5" stroke="#FFE500" stroke-width="1.2"/>
              </svg>
              <span style="font-family:'JetBrains Mono',monospace;font-size:0.8rem;color:#FFE500;font-weight:700">propagate.yaml</span>
            </div>
            <!-- code -->
            <pre style="font-family:'JetBrains Mono',monospace;font-size:0.8rem;line-height:1.8;padding:1.5rem 1.5rem 2rem;overflow-x:auto;color:#ccc;margin:0"><span style="color:#555"># generated by propagate init</span>
<span style="color:#FFE500">version</span><span style="color:#888">:</span> <span style="color:#fff">1</span>
<span style="color:#FFE500">team</span><span style="color:#888">:</span> <span style="color:#fff">acme-api</span>
<span style="color:#FFE500">admin</span><span style="color:#888">:</span> <span style="color:#fff">alice@acme.com</span>

<span style="color:#FFE500">members</span><span style="color:#888">:</span>
  <span style="color:#888">-</span> <span style="color:#FFE500">handle</span><span style="color:#888">:</span> <span style="color:#fff">alice@acme.com</span>
    <span style="color:#FFE500">role</span><span style="color:#888">:</span>   <span style="color:#fff">admin</span>
    <span style="color:#FFE500">scopes</span><span style="color:#888">:</span> <span style="color:#fff">[dev, staging, prod]</span>
  <span style="color:#888">-</span> <span style="color:#FFE500">handle</span><span style="color:#888">:</span> <span style="color:#fff">bob@acme.com</span>
    <span style="color:#FFE500">role</span><span style="color:#888">:</span>   <span style="color:#fff">member</span>
    <span style="color:#FFE500">scopes</span><span style="color:#888">:</span> <span style="color:#fff">[dev]</span>

<span style="color:#FFE500">variables</span><span style="color:#888">:</span>
  <span style="color:#888">-</span> <span style="color:#FFE500">name</span><span style="color:#888">:</span>  <span style="color:#fff">DATABASE_URL</span>
    <span style="color:#FFE500">scope</span><span style="color:#888">:</span> <span style="color:#fff">dev</span>
    <span style="color:#FFE500">rev</span><span style="color:#888">:</span>   <span style="color:#fff">00003</span>
  <span style="color:#888">-</span> <span style="color:#FFE500">name</span><span style="color:#888">:</span>  <span style="color:#fff">API_TOKEN</span>
    <span style="color:#FFE500">scope</span><span style="color:#888">:</span> <span style="color:#fff">dev</span>
    <span style="color:#FFE500">rev</span><span style="color:#888">:</span>   <span style="color:#fff">00003</span>
  <span style="color:#888">-</span> <span style="color:#FFE500">name</span><span style="color:#888">:</span>  <span style="color:#fff">STRIPE_SECRET</span>
    <span style="color:#FFE500">scope</span><span style="color:#888">:</span> <span style="color:#fff">staging</span>
    <span style="color:#FFE500">rev</span><span style="color:#888">:</span>   <span style="color:#fff">00001</span></pre>
          </div>

        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 px-6" style="position:relative;z-index:1;border-top:2px solid #fff;background:#FFE500">
      <div class="max-w-2xl mx-auto text-center">
        <div
          class="inline-block px-3 py-1 text-xs font-bold font-mono mb-8 uppercase tracking-widest"
          style="border:2px solid #000;box-shadow:3px 3px 0 #000;color:#000"
        >
          Open source · MIT license
        </div>
        <h2 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4" style="color:#000;letter-spacing:-0.03em">
          Stop leaking<br />.env files.
        </h2>
        <p class="text-lg mb-10" style="color:#333">
          Propagate is open source. Star it, use it, contribute to it.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <div
            class="flex items-center gap-3 px-5 py-3 font-mono text-sm font-bold cursor-pointer"
            style="background:#fff;color:#000;border:2px solid #000;box-shadow:4px 4px 0 #000"
            onclick="navigator.clipboard.writeText('go install github.com/renton4code/propagate-cli/cli/cmd/propagate@latest')"
          >
            <span style="color:#888">$</span>
            <span>go install propagate@latest</span>
          </div>
          <a
            href="https://github.com/renton4code/propagate-cli"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-5 py-3 text-sm font-bold"
            style="background:#000;color:#FFE500;border:2px solid #000;box-shadow:4px 4px 0 #000"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
            Star on GitHub
          </a>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="py-8 px-6" style="position:relative;z-index:1;border-top:2px solid #fff;background:#0c0c0c">
    <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm">
      <div class="flex items-center gap-1">
        <div class="mt-[3px]"><FishSvg width={24} height={18} /></div>
        <span style="font-weight:700">propagate</span>
      </div>
      <p style="color:#555">Open source under the MIT License</p>
    </div>
  </footer>
</Layout>
